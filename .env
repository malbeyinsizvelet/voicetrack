# ============================================================
# VoiceTrack Studio — Environment Variables
# ============================================================
#
# Bu dosyayı kopyala: cp .env.example .env
# Sonra .env içindeki değerleri doldur.
# .env dosyasını asla git'e commit etme!
#
# ============================================================
# HUGGING FACE STORAGE
# ============================================================
#
# HF Access Token:
#   1. https://huggingface.co/settings/tokens adresine git
#   2. "New token" oluştur
#   3. Type: "Write" seç (repo'ya yazabilmek için)
#   4. Aşağıya yapıştır
#
VITE_HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# HF Dataset Repo ID:
#   1. https://huggingface.co/new-dataset adresine git
#   2. Repo adı: voicetrack-storage (veya istediğin isim)
#   3. Visibility: Private (ses dosyaları için önerilir)
#   4. "Create dataset" tıkla
#   5. Aşağıya "kullanici-adi/repo-adi" formatında yaz
#
VITE_HF_REPO=kullanici-adin/voicetrack-storage

# HF Branch (genellikle main, değiştirme):
VITE_HF_BRANCH=main

# ============================================================
# GELECEKTEKİ BACKEND DEĞİŞKENLERİ (şimdilik boş)
# ============================================================

# Gerçek backend API eklendiğinde:
# VITE_API_URL=https://api.voicetrack.io
# VITE_API_KEY=...
